# Dropbox Configuration
# Get your access token from: https://www.dropbox.com/developers/apps
# 1. Create an app at https://www.dropbox.com/developers/apps
# 2. Choose "Scoped access" -> "App folder"
# 3. Set app name (e.g., backup-opencode)
# 4. Go to Permissions tab and enable:
#    - files.content.write
#    - files.content.read
#    - files.metadata.read
#    - files.metadata.write
# 5. Go to Settings -> OAuth 2 -> Generate access token
# 6. Copy the token below

DROPBOX_TOKEN=your_dropbox_access_token_here

# Folder name in Dropbox (will be created if not exists)
DROPBOX_FOLDER=OpenCodeBackup
